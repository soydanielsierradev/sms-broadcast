{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SMS Broadcast",
  "version": "0.1.0",
  "identifier": "com.smsbroadcast.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SMS Broadcast",
        "width": 1200,
        "height": 800,
        "minWidth": 1200,
        "minHeight": 800,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "SMS Broadcast",
    "category": "Business",
    "shortDescription": "Bulk SMS broadcast desktop client",
    "longDescription": "SMS Broadcast — manage contacts, lists, and campaigns to send bulk SMS via a paired Android device.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["en-US", "es-AR"]
      },
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": true,
        "languages": ["English", "Spanish"]
      }
    }
  }
}
